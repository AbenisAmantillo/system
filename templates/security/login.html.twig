<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            height: 100vh;
            display: flex;
            position: relative;
            overflow: hidden;
        }

        /* Background Image */
        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=1920') center/cover no-repeat;
            filter: brightness(0.7);
            z-index: 0;
        }

        /* White vertical bar */
        .vertical-bar {
            position: absolute;
            left: 40%;
            top: 0;
            width: 4px;
            height: 100%;
            background: white;
            z-index: 1;
        }

        /* Login Container */
        .login-container {
            position: relative;
            z-index: 2;
            margin-left: auto;
            padding: 40px 50px;
            width: 100%;
            max-width: 480px;
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
        }

        .login-title {
            color: white;
            font-size: 32px;
            font-weight: 300;
            margin-bottom: 40px;
            text-align: left;
            animation: fadeInDown 0.6s ease-out;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .form-group {
            margin-bottom: 20px;
            animation: fadeInUp 0.6s ease-out;
            animation-fill-mode: both;
        }

        .form-group:nth-child(2) {
            animation-delay: 0.1s;
        }

        .form-group:nth-child(3) {
            animation-delay: 0.2s;
        }

        label {
            display: block;
            color: white;
            font-size: 13px;
            margin-bottom: 8px;
            font-weight: 400;
        }

        .input-wrapper {
            position: relative;
        }

        .form-control {
            width: 100%;
            padding: 14px 40px 14px 16px;
            border: none;
            border-radius: 25px;
            font-size: 14px;
            background: white;
            color: #333;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            outline: none;
            box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.3);
        }

        .form-control::placeholder {
            color: #999;
        }

        .input-icon {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #999;
            cursor: pointer;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            margin: 25px 0;
            animation: fadeInUp 0.6s ease-out 0.3s;
            animation-fill-mode: both;
        }

        .checkbox-group input[type="checkbox"] {
            width: 18px;
            height: 18px;
            margin-right: 8px;
            cursor: pointer;
        }

        .checkbox-group label {
            margin: 0;
            font-size: 13px;
            cursor: pointer;
        }

        .divider {
            text-align: center;
            color: white;
            font-size: 12px;
            margin: 25px 0;
            position: relative;
            animation: fadeInUp 0.6s ease-out 0.4s;
            animation-fill-mode: both;
        }

        .divider::before,
        .divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 40%;
            height: 1px;
            background: rgba(255, 255, 255, 0.3);
        }

        .divider::before {
            left: 0;
        }

        .divider::after {
            right: 0;
        }

        .social-login {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 25px;
            animation: fadeInUp 0.6s ease-out 0.5s;
            animation-fill-mode: both;
        }

        .social-btn {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            border: none;
            background: rgba(255, 255, 255, 0.2);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .social-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
        }

        .forgot-password {
            text-align: center;
            margin: 20px 0;
            animation: fadeInUp 0.6s ease-out 0.6s;
            animation-fill-mode: both;
        }

        .forgot-password a {
            color: white;
            font-size: 13px;
            text-decoration: none;
        }

        .forgot-password a:hover {
            text-decoration: underline;
        }

        .btn-login {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 25px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            background: #dc3545;
            color: white;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            animation: fadeInUp 0.6s ease-out 0.7s;
            animation-fill-mode: both;
        }

        .btn-login:hover {
            background: #c82333;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(220, 53, 69, 0.4);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 13px;
        }

        .alert-danger {
            background-color: rgba(220, 53, 69, 0.9);
            color: white;
        }

        .alert-info {
            background-color: rgba(13, 202, 240, 0.9);
            color: white;
        }

        .alert a {
            color: white;
            text-decoration: underline;
            font-weight: 600;
        }

        @media (max-width: 768px) {
            .vertical-bar {
                display: none;
            }

            .login-container {
                margin: 0;
                max-width: 100%;
                padding: 40px 30px;
            }
        }
    </style>
</head>
<body>
    <div class="vertical-bar"></div>
    
    <div class="login-container">
        <h1 class="login-title">Login</h1>
        
        <!-- This is where your Twig template content goes -->
        <form method="post">
            <!-- Error Alert -->
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <!-- Already Logged In Alert -->
            {% if app.user %}
                <div class="alert alert-info">
                    You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Logout</a>
                </div>
            {% endif %}

            <!-- Username Input -->
            <div class="form-group">
                <label for="inputUsername">Username</label>
                <div class="input-wrapper">
                    <input type="text" 
                           value="{{ last_username }}" 
                           name="username" 
                           id="inputUsername" 
                           class="form-control" 
                           placeholder="Enter your username" 
                           autocomplete="username" 
                           required 
                           autofocus>
                    <span class="input-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </span>
                </div>
            </div>

            <!-- Password Input -->
            <div class="form-group">
                <label for="inputPassword">Password</label>
                <div class="input-wrapper">
                    <input type="password" 
                           name="password" 
                           id="inputPassword" 
                           class="form-control" 
                           placeholder="Enter your password" 
                           autocomplete="current-password" 
                           required>
                    <span class="input-icon" onclick="togglePassword()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </span>
                </div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <!-- Remember Me -->
            <div class="checkbox-group">
                <input type="checkbox" name="_remember_me" id="remember_me">
                <label for="remember_me">Remember me</label>
            </div>

            <!-- Login Button -->
            <button class="btn-login" type="submit">
                Login →
            </button>

            <!-- Forgot Password -->
            <div class="forgot-password">
                <a href="{{ path('app_register') }}">Don't have an account?</a>
            </div>
        </form>
    </div>

    <script>
        function togglePassword() {
            const passwordInput = document.getElementById('inputPassword');
            passwordInput.type = passwordInput.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>