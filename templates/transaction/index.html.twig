{% extends 'layouts/admin_layout.html.twig' %}

{% block title %}Transaction Report{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('app') }}
{% endblock %}

{% block content %}
<div class="transaction-container">
    <!-- Header Section -->
    <div class="transaction-header-section">
        <div class="header-left">
            <h1>
                Transaction Report
            </h1>
            <p>View and manage all property transactions and payments</p>
        </div>
    </div>

    <!-- Search and Filter Bar -->
    <div class="toolbar">
        <div class="search-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
            </svg>
            <input type="text" id="searchInput" placeholder="Search any parameter...">
        </div>
                <div class="toolbar-actions">
            <button class="btn btn-secondary" onclick="window.print()">Export</button>
        </div>
    </div>

    <!-- Transaction Report -->
    <div class="transaction-section">
        <div class="transaction-table-wrapper">
            <table class="transaction-table">
                <thead>
                    <tr>
                        <th>Transaction ID <span class="sort-icon"></span></th>
                        <th>Customer Name <span class="sort-icon"></span></th>
                        <th>Property Name <span class="sort-icon"></span></th>
                        <th>Downpayment</th>
                        <th>Monthly</th>
                        <th>Date <span class="sort-icon"></span></th>
                    </tr>
                </thead>
                <tbody>
                    {% for transaction in transactions %}
                    <tr>
                        <td>{{ transaction.order_id }}</td>
                        <td>{{ transaction.customer_name }}</td>
                        <td>{{ transaction.property_name }}</td>
                        <td>{{ transaction.purchase_type }}</td>
                        <td>{{ transaction.price }}</td>
                        <td>{{ transaction.date }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 2rem; color: #6b7280;">
                            No transactions found.
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('app') }}
{% endblock %}




