<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Amantillo Property Co. - Find Your Dream Home</title>
    <link rel="stylesheet" href="{{ asset('styles/landing.css') }}">
</head>
<body>
    <!-- Header Navigation -->
    <header class="header">
        <div class="nav-container">
            <a href="/" class="logo">
                <div class="logo-image"></div>
                <span class="logo-text">The Amantillo Property Co.</span>
            </a>
            <div class="nav-buttons">
                <a href="/login" class="btn btn-login">Log In</a>
                <a href="/signup" class="btn btn-signup">Sign Up</a>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Find Your Dream Home</h1>
            <p>Discover the perfect property from our extensive collection of premium real estate</p>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats">
        <div class="stats-container">
            {% for stat in stats %}
            <div class="stat-item">
                <h3>{{ stat.number }}</h3>
                <p>{{ stat.label }}</p>
            </div>
            {% endfor %}
        </div>
    </section>

    <!-- Featured Properties Section -->
    <section class="featured">
        <div class="section-header">
            <h2>Featured Properties</h2>
            <p>Explore our handpicked selection of premium properties</p>
        </div>
        
        <div class="properties-grid">
            {% for property in featured_properties %}
            <div class="property-card">
                <div class="property-image">
                    {% if property.imageFileName %}
                        <img src="{{ asset('uploads/property_images/' ~ property.imageFileName) }}" alt="{{ property.title }}">
                    {% else %}
                        <img src="https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=800&q=80" alt="{{ property.title }}">
                    {% endif %}
                    <span class="featured-badge">Featured</span>
                </div>
                <div class="property-details">
                    <div class="property-price">₱{{ property.price|number_format(0, '.', ',') }}</div>
                    <div class="property-title">{{ property.title }}</div>
                    <div class="property-location">
                        📍 {{ property.address }}
                    </div>
                    <button class="btn-view">View Details</button>
                </div>
            </div>
            {% else %}
            <div style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <p style="color: #666; font-size: 1.1rem;">No properties available at the moment.</p>
            </div>
            {% endfor %}
        </div>

        <div class="view-all-btn">
            <a href="{{ path('app_login') }}" class="btn btn-outline">View All Properties</a>
        </div>
    </section>

    <!-- Services Section -->
    <section class="services">
        <div class="services-container">
            <div class="section-header">
                <h2>Our Services</h2>
                <p>Comprehensive real estate solutions tailored to your needs</p>
            </div>
            
            <div class="services-grid">
                {% for service in services %}
                <div class="service-card">
                    <div class="service-icon">
                        {% if service.icon == 'home' %}
                            🏠
                        {% elseif service.icon == 'building' %}
                            🏢
                        {% elseif service.icon == 'clock' %}
                            🕐
                        {% elseif service.icon == 'furniture' %}
                            🪑
                        {% elseif service.icon == 'chart' %}
                            📊
                        {% endif %}
                    </div>
                    <h3>{{ service.title }}</h3>
                    <p>{{ service.description }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
        <h2>Ready to Find Your Perfect Property?</h2>
        <p>Join thousands of satisfied clients who found their dream homes with us</p>
        <div class="cta-buttons">
            <a href="{{ path('app_login') }}" class="btn btn-white">Get Started</a>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>About Us</h3>
                    <p>Premium Real Estate platform connecting buyers, sellers and renters to their ideal properties.</p>
                </div>
                
                <div class="footer-section">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="#">Properties</a></li>
                        <li><a href="#">Agents</a></li>
                        <li><a href="#">About</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
                
                <div class="footer-section">
                    <h3>Contact Info</h3>
                    <p>Email: info@amarillo.com</p>
                    <p>Phone: +1 (555) 123-4567</p>
                    <p>Address: 123 Real Estate Blvd</p>
                </div>
                
                <div class="footer-section">
                    <h3>Newsletter</h3>
                    <p>Subscribe to get the latest property listings</p>
                    <form class="newsletter-form">
                        <input type="email" placeholder="Your email">
                        <button type="submit" class="btn-subscribe">Subscribe</button>
                    </form>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p>&copy; 2024 Premium Real Estate. All rights reserved.</p>
            </div>
        </div>
    </footer>
</body>
</html>